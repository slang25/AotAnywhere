--- !tapi-tbd
tbd-version:     4
targets:         [ x86_64-macos, arm64-macos ]
install-name:    '/usr/lib/libobjc.A.dylib'
exports:
  - targets:         [ x86_64-macos, arm64-macos ]
    symbols:          [ __objc_empty_cache, _objc_alloc_init, _objc_autoreleasePoolPop,
                        _objc_autoreleasePoolPush, _objc_msgSend, _objc_opt_self, _objc_release,
                        _objc_retainAutorelease, _objc_retainAutoreleasedReturnValue ]
...
