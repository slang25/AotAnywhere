#!/bin/bash
#
# clang - Wrapper to redirect clang calls to 'zig cc'.
# This script intelligently modifies arguments for native and cross-compilation.
#
# STRATEGY:
# 1. Extract the target triple (e.g., --target=x86_64-macos).
# 2. Correct the triple to what Zig expects (e.g., --target=x86_64-macos-none).
# 3. Filter the original arguments, removing flags that break zig cc.
# 4. Execute zig cc with the corrected target FIRST, followed by the filtered args.

set -euo pipefail

main() {
    # Use a bash array to preserve arguments with spaces
    local -a original_args=("$@")

    if [[ -n "${ZIG_SHIM_DEBUG:-}" ]]; then
        echo "[DEBUG] Original args from build system:"
        printf "  '%s'\n" "${original_args[@]}"
    fi

    if ! command -v zig &>/dev/null; then
        echo "Error: zig is not on the PATH." >&2
        exit 1
    fi

    # --- 1. Extract and Correct the Target ---
    local zig_target=""
    for arg in "${original_args[@]}"; do
        if [[ "$arg" == --target=* ]]; then
            # Correct the triple by ensuring it ends with '-none'
            zig_target="${arg}-none"
            zig_target="${zig_target//-macos-none-none/-macos-none}" # Fix double adding
            break
        fi
    done

    # If no target was found, we can't continue for cross-compilation
    if [[ -z "$zig_target" ]]; then
        echo "[ERROR] No '--target' flag found in arguments. Cannot proceed." >&2
        # As a fallback, try to execute zig cc directly, which might work for native builds.
        exec zig cc "${original_args[@]}"
    fi
    echo "[clang.sh] Detected and corrected target: $zig_target"

    # --- 2. Filter the remaining arguments ---
    local -a filtered_args=()
    echo "[clang.sh] Filtering arguments for Zig..."
    for arg in "${original_args[@]}"; do
        case "$arg" in
        # DISCARD the original, incorrect target flag
        --target=*)
            ;; # Do nothing

        # DISCARD problematic flags
        -ld_classic | -L/usr/lib/swift)
            echo "[clang.sh] Removing unsupported flag: $arg"
            ;;
        -lobjc | -lswiftCore | -lswiftFoundation | -lz | -licucore | -lm | -ldl)
            echo "[clang.sh] Removing redundant system library flag: $arg"
            ;;

        # FIX bare framework names (though linking frameworks might now work automatically)
        CoreFoundation | Foundation | Security | AppKit | GSS | CryptoKit)
            echo "[clang.sh] Fixing bare framework: '$arg' -> '-framework $arg'"
            filtered_args+=("-framework" "$arg")
            ;;

        # KEEP everything else
        *)
            filtered_args+=("$arg")
            ;;
        esac
    done

    # --- 3. Rebuild and Execute the Command ---
    local -a final_command=("cc" "$zig_target")
    final_command+=("${filtered_args[@]}")

    if [[ -n "${ZIG_SHIM_DEBUG:-}" ]]; then
        echo "[DEBUG] Final modified command to be executed:"
        printf "  'zig' "
        printf "'%s' " "${final_command[@]}"
        echo
    fi

    # The final command is 'zig cc --target=... <filtered_args>'
    exec zig "${final_command[@]}"
}

# --- Script Entry Point ---
main "$@"
