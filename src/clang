#!/bin/bash
#
# clang - Wrapper to redirect clang calls to 'zig cc'.
# This script intelligently modifies arguments for native and cross-compilation.

set -euo pipefail

# --- Main Logic ---
main() {
    local -a args=("$@")

    if [[ -n "${ZIG_SHIM_DEBUG:-}" ]]; then
        echo "[DEBUG] Original args from build system:"
        printf "  '%s'\n" "${args[@]}"
    fi

    if ! command -v zig &>/dev/null; then
        echo "Error: zig is not on the PATH." >&2
        exit 1
    fi

    local is_macos_target=false
    local is_macos_host=false
    if [[ "$OSTYPE" == "darwin"* ]]; then
        is_macos_host=true
    fi
    for arg in "${args[@]}"; do
        case "$arg" in
        *-apple-darwin* | -framework | *-macos*)
            is_macos_target=true
            break
            ;;
        esac
    done

    local -a filtered_args=()
    if [[ "$is_macos_target" == true ]]; then
        echo "[clang.sh] Detected macOS target. Processing args for Zig..."
        process_macos_args "${args[@]}"
    else
        echo "[clang.sh] Detected Linux target. Processing args for Zig..."
        process_linux_args "${args[@]}"
    fi

    if [[ -n "${ZIG_SHIM_DEBUG:-}" ]]; then
        echo "[DEBUG] Final modified command to be executed:"
        printf "  'zig' 'cc' "
        printf "'%s' " "${filtered_args[@]}"
        echo
    fi

    exec zig cc "${filtered_args[@]}"
}

# --- Argument Processing Functions ---

process_macos_args() {
    echo "[clang.sh] Applying macOS argument transformations."

    while [[ $# -gt 0 ]]; do
        local current_arg="$1"
        local next_arg="${2:-}"

        case "$current_arg" in
        # Case 1: Handle correctly formed framework flags by consuming both parts.
        -framework)
            if [[ -n "$next_arg" ]]; then
                filtered_args+=("$current_arg" "$next_arg")
                shift 2
            else
                echo "[clang.sh] Warning: Discarding dangling '-framework' flag." >&2
                shift 1
            fi
            ;;

        # Case 2: Fix bare framework names from the build system.
        CoreFoundation | Foundation | Security | AppKit | GSS | CryptoKit)
            echo "[clang.sh] Fixing bare framework: '$current_arg' -> '-framework $current_arg'"
            filtered_args+=("-framework" "$current_arg")
            shift 1
            ;;

        # === FIX: START ===
        # Case 3: Remove redundant system library flags. On macOS, these are
        # implicitly linked via libSystem when any framework is used.
        # 'zig cc' fails trying to find them as standalone .tbd files.
        -lobjc | -lswiftCore | -lswiftFoundation | -lz | -licucore | -lm | -ldl)
            echo "[clang.sh] Removing redundant macOS system library flag: $current_arg"
            shift 1 # Consume and discard the flag
            ;;
        # === FIX: END ===

        # Case 4: Remove other flags unsupported by zig's linker or that
        # break cross-compilation.
        -ld_classic | -L/usr/lib/swift)
            echo "[clang.sh] Removing unsupported/problematic flag: $current_arg"
            shift 1
            ;;

        # Default case: Keep any other argument.
        *)
            filtered_args+=("$current_arg")
            shift 1
            ;;
        esac
    done
}

process_linux_args() {
    # This function remains unchanged.
    filtered_args+=("-Wl,-u,__Module")

    while [[ $# -gt 0 ]]; do
        case "$1" in
        -lz | -pie | -Wl,-pie | -Wl,-e0x0)
            shift
            ;;
        --discard-all)
            filtered_args+=("--as-needed")
            shift
            ;;
        "'-Wl,-rpath,\$ORIGIN'")
            filtered_args+=('-Wl,-rpath,$ORIGIN')
            shift
            ;;
        *)
            filtered_args+=("$1")
            shift
            ;;
        esac
    done
}

# --- Script Entry Point ---
main "$@"
