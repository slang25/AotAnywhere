#!/bin/bash
#
# clang - Wrapper to redirect clang calls to 'zig cc'.
# This script intelligently modifies arguments for native and cross-compilation.

set -euo pipefail

# --- Main Logic ---
main() {
    # Use a bash array to preserve arguments with spaces. This is critical.
    local -a args=("$@")

    # --- Optional Debug Logging ---
    if [[ -n "${ZIG_SHIM_DEBUG:-}" ]]; then
        echo "[DEBUG] Original args:"
        printf "  '%s'\n" "${args[@]}"
    fi

    # --- Dependency Check ---
    if ! command -v zig &>/dev/null; then
        echo "Error: zig is not on the PATH." >&2
        exit 1
    fi

    # --- Target and Host Detection ---
    local is_macos_target=false
    local is_macos_host=false

    if [[ "$OSTYPE" == "darwin"* ]]; then
        is_macos_host=true
    fi

    # Loop through args to detect target. More robust than string matching.
    for arg in "${args[@]}"; do
        case "$arg" in
        *-apple-darwin* | -framework | *-macos*)
            is_macos_target=true
            break
            ;;
        esac
    done

    # --- Argument Processing ---
    local -a filtered_args=()
    if [[ "$is_macos_target" == true && "$is_macos_host" == false ]]; then
        # --- Case 1: Cross-compiling to macOS (e.g., from Linux) ---
        echo "[clang.sh] Detected macOS cross-compilation target."
        process_macos_cross_compile_args "${args[@]}"
    elif [[ "$is_macos_target" == true ]]; then
        # --- Case 2: Native compilation on macOS ---
        echo "[clang.sh] Detected native macOS compilation."
        process_macos_native_args "${args[@]}"
    else
        # --- Case 3: Compiling for Linux ---
        echo "[clang.sh] Detected Linux compilation target."
        process_linux_args "${args[@]}"
    fi

    # The processing functions will populate the 'filtered_args' array.

    # --- Optional Debug Logging ---
    if [[ -n "${ZIG_SHIM_DEBUG:-}" ]]; then
        echo "[DEBUG] Final command:"
        printf "  'zig' 'cc' "
        printf "'%s' " "${filtered_args[@]}"
        echo
    fi

    # --- Execution ---
    # The "${filtered_args[@]}" syntax correctly handles args with spaces.
    zig cc "${filtered_args[@]}"
}

# --- Argument Processing Functions ---

process_macos_cross_compile_args() {
    echo "Warning: Removing system libs/frameworks for cross-compilation."
    local -a input_args=("$@")
    while [[ $# -gt 0 ]]; do
        case "$1" in
        # Flags to remove completely
        -ld_classic | -lobjc | -lz | -ldl | -lm | -licucore | -lswiftCore | -lswiftFoundation)
            shift
            ;;
        # Library path to remove (no argument)
        -L/usr/lib/swift)
            shift
            ;;
        # Framework flag that consumes the next argument - remove both
        -framework)
            shift 2
            ;;
        *)
            filtered_args+=("$1")
            shift
            ;;
        esac
    done
}

process_macos_native_args() {
    local -a extra_args=()
    if command -v xcrun &>/dev/null; then
        local sdk_path
        sdk_path=$(xcrun --show-sdk-path 2>/dev/null || true)
        if [[ -n "$sdk_path" && -d "$sdk_path" ]]; then
            echo "Using macOS SDK: $sdk_path"
            extra_args+=("-isysroot" "$sdk_path")
            extra_args+=("-L$sdk_path/usr/lib")
            extra_args+=("-L$sdk_path/usr/lib/swift")
            extra_args+=("-F$sdk_path/System/Library/Frameworks")
        else
            echo "Warning: Could not determine macOS SDK path. Using fallbacks." >&2
            extra_args+=("-L/usr/lib")
            extra_args+=("-L/usr/lib/swift")
            extra_args+=("-F/System/Library/Frameworks")
        fi
    else
        echo "Warning: xcrun not available. Using fallbacks." >&2
        extra_args+=("-L/usr/lib")
        extra_args+=("-L/usr/lib/swift")
        extra_args+=("-F/System/Library/Frameworks")
    fi

    # Prepend SDK flags and then filter the rest of the arguments.
    filtered_args+=("${extra_args[@]}")
    while [[ $# -gt 0 ]]; do
        case "$1" in
        -ld_classic) # Remove unsupported flag
            shift
            ;;
        *)
            filtered_args+=("$1")
            shift
            ;;
        esac
    done
}

process_linux_args() {
    # Prepend required linker flag
    filtered_args+=("-Wl,-u,__Module")

    while [[ $# -gt 0 ]]; do
        case "$1" in
        # Flags to remove completely
        -lz | -pie | -Wl,-pie | -Wl,-e0x0)
            shift
            ;;
        # Flags to replace
        --discard-all)
            filtered_args+=("--as-needed")
            shift
            ;;
        # .NET issue workaround (removes single quotes)
        "'-Wl,-rpath,\$ORIGIN'")
            # Use single quotes here to add the literal string to the array.
            filtered_args+=('-Wl,-rpath,$ORIGIN')
            shift
            ;;
        *)
            filtered_args+=("$1")
            shift
            ;;
        esac
    done
}

# --- Script Entry Point ---
# Pass all script arguments to the main function.
main "$@"
