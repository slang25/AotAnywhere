#!/bin/bash
#
# clang - Wrapper to redirect clang calls to 'zig cc'.
# This script intelligently modifies arguments for native and cross-compilation.

set -euo pipefail

# --- Main Logic ---
main() {
    local -a args=("$@")

    if [[ -n "${ZIG_SHIM_DEBUG:-}" ]]; then
        echo "[DEBUG] Original args from build system:"
        printf "  '%s'\n" "${args[@]}"
    fi

    if ! command -v zig &>/dev/null; then
        echo "Error: zig is not on the PATH." >&2
        exit 1
    fi

    local is_macos_target=false
    local is_macos_host=false
    if [[ "$OSTYPE" == "darwin"* ]]; then
        is_macos_host=true
    fi
    for arg in "${args[@]}"; do
        case "$arg" in
        *-apple-darwin* | -framework | *-macos*)
            is_macos_target=true
            break
            ;;
        esac
    done

    local -a filtered_args=()
    if [[ "$is_macos_target" == true && "$is_macos_host" == false ]]; then
        echo "[clang.sh] Detected macOS cross-compilation. Processing args for Zig..."
        process_macos_args "${args[@]}"
    elif [[ "$is_macos_target" == true ]]; then
        echo "[clang.sh] Detected native macOS compilation. Processing args for Zig..."
        process_macos_args "${args[@]}" # The same logic applies
    else
        echo "[clang.sh] Detected Linux compilation target. Processing args for Zig..."
        process_linux_args "${args[@]}"
    fi

    if [[ -n "${ZIG_SHIM_DEBUG:-}" ]]; then
        echo "[DEBUG] Final modified command to be executed:"
        printf "  'zig' 'cc' "
        printf "'%s' " "${filtered_args[@]}"
        echo
    fi

    exec zig cc "${filtered_args[@]}"
}

# --- Argument Processing Functions ---

process_macos_args() {
    echo "[clang.sh] Applying macOS argument transformations."

    while [[ $# -gt 0 ]]; do
        local current_arg="$1"
        # Safely get the next argument, defaulting to empty if it doesn't exist
        local next_arg="${2:-}"

        case "$current_arg" in
        # Case 1: A framework that already has the correct flag.
        # We must consume both arguments in one step.
        -framework)
            if [[ -n "$next_arg" ]]; then
                filtered_args+=("$current_arg" "$next_arg")
                shift 2 # Consume both '-framework' and its value
            else
                echo "[clang.sh] Warning: Discarding dangling '-framework' flag." >&2
                shift 1 # Consume just the flag
            fi
            ;;

        # Case 2: A bare framework name. This is what we need to fix.
        # We prepend '-framework' and consume only the current argument.
        CoreFoundation | Foundation | Security | AppKit | GSS | CryptoKit)
            echo "[clang.sh] Fixing bare framework: '$current_arg' -> '-framework $current_arg'"
            filtered_args+=("-framework" "$current_arg")
            shift 1 # Consume just the framework name
            ;;

        # Case 3: Flags that LLD (Zig's linker) does not support or that
        # break cross-compilation. Consume and discard them.
        -ld_classic | -L/usr/lib/swift)
            shift 1
            ;;

        # Default case: Keep any other argument.
        *)
            filtered_args+=("$current_arg")
            shift 1
            ;;
        esac
    done
}

process_linux_args() {
    # This function remains unchanged as the issue is specific to macOS.
    filtered_args+=("-Wl,-u,__Module")

    while [[ $# -gt 0 ]]; do
        case "$1" in
        -lz | -pie | -Wl,-pie | -Wl,-e0x0)
            shift
            ;;
        --discard-all)
            filtered_args+=("--as-needed")
            shift
            ;;
        "'-Wl,-rpath,\$ORIGIN'")
            filtered_args+=('-Wl,-rpath,$ORIGIN')
            shift
            ;;
        *)
            filtered_args+=("$1")
            shift
            ;;
        esac
    done
}

# --- Script Entry Point ---
main "$@"
