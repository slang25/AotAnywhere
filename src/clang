#!/bin/bash
#
# clang - Wrapper to redirect clang calls to 'zig cc'.
# This script intelligently modifies arguments for native and cross-compilation.
#
# STRATEGY:
# 1. Extract the target triple (e.g., --target=x86_64-macos).
# 2. Correct the triple to what Zig expects (e.g., --target=x86_64-macos-none).
# 3. Create a final command list, starting with 'cc' and the corrected target.
# 4. Use a robust 'while' loop to process the rest of the arguments, handling
#    pairs like '-framework Name' correctly and discarding problematic flags.
# 5. Append the filtered arguments to the final command and execute.

set -euo pipefail

main() {
    local -a original_args=("$@")

    if [[ -n "${ZIG_SHIM_DEBUG:-}" ]]; then
        echo "[DEBUG] Original args from build system:"
        printf "  '%s'\n" "${original_args[@]}"
    fi

    if ! command -v zig &>/dev/null; then
        echo "Error: zig is not on the PATH." >&2
        exit 1
    fi

    # --- 1. Extract and Correct the Target ---
    local zig_target=""
    for arg in "${original_args[@]}"; do
        if [[ "$arg" == --target=* ]]; then
            # Correct the triple by ensuring it ends with '-none'
            zig_target="${arg}-none"
            zig_target="${zig_target//-macos-none-none/-macos-none}" # Prevent double adding
            break
        fi
    done

    if [[ -z "$zig_target" ]]; then
        echo "[ERROR] No '--target' flag found for macOS cross-build. Cannot proceed." >&2
        exit 1
    fi
    echo "[clang.sh] Detected and corrected target: $zig_target"

    # --- 2. Build the final command, starting with the corrected target ---
    local -a final_command=("cc" "$zig_target")

    # --- 3. Robustly filter the remaining arguments using a while loop ---
    echo "[clang.sh] Filtering arguments for Zig..."
    while [[ $# -gt 0 ]]; do
        local current_arg="$1"
        local next_arg="${2:-}"

        case "$current_arg" in
        # DISCARD the original, incorrect target flag
        --target=*)
            shift 1
            ;;

        # KEEP correctly formed framework flags by consuming both parts.
        -framework)
            if [[ -n "$next_arg" ]]; then
                final_command+=("$current_arg" "$next_arg")
                shift 2
            else
                echo "[clang.sh] Warning: Discarding dangling '-framework' flag." >&2
                shift 1
            fi
            ;;

        # FIX bare framework names (just in case)
        CoreFoundation | Foundation | Security | AppKit | GSS | CryptoKit)
            echo "[clang.sh] Fixing bare framework: '$current_arg' -> '-framework $current_arg'"
            final_command+=("-framework" "$current_arg")
            shift 1
            ;;

        # DISCARD redundant system library flags and other unsupported flags
        -lobjc | -lswiftCore | -lswiftFoundation | -lz | -licucore | -lm | -ldl | -ld_classic | -L/usr/lib/swift)
            echo "[clang.sh] Removing problematic flag: $current_arg"
            shift 1
            ;;

        # KEEP everything else
        *)
            final_command+=("$current_arg")
            shift 1
            ;;
        esac
    done

    # --- 4. Execute the final, correctly ordered command ---
    if [[ -n "${ZIG_SHIM_DEBUG:-}" ]]; then
        echo "[DEBUG] Final modified command to be executed:"
        printf "  'zig' "
        printf "'%s' " "${final_command[@]}"
        echo
    fi

    exec zig "${final_command[@]}"
}

# --- Script Entry Point ---
# Use "$@" to pass all original arguments to the main function's while loop
main "$@"
