#!/bin/bash

# Check if zig is available - needed for all scenarios now
if ! command -v zig &> /dev/null; then
    echo "Error: zig is not on the PATH. Install zig and make sure it's on PATH. Follow instructions at https://github.com/MichalStrehovsky/PublishAotCross."
    exit 1
fi

# Get all arguments
args="$@"

# Detect if this is a macOS target by looking for macOS-specific flags or target
is_macos_target=false
if [[ "$args" == *"-apple-darwin"* ]] || [[ "$args" == *"-framework"* ]] || [[ "$args" == *"-exported_symbols_list"* ]]; then
    is_macos_target=true
fi

# Detect if we're running on macOS (native compilation)
is_macos_host=false
if [[ "$OSTYPE" == "darwin"* ]]; then
    is_macos_host=true
fi

# Only apply cross-compilation fixes when targeting macOS from a non-macOS host
is_cross_compiling_to_macos=false
if [ "$is_macos_target" = true ] && [ "$is_macos_host" = false ]; then
    is_cross_compiling_to_macos=true
fi

if [ "$is_cross_compiling_to_macos" = true ]; then
    # macOS cross-compilation argument handling
    echo "Cross-compiling to macOS target using PublishAotCross..."
    
    # Handle macOS-specific flags that zig doesn't support
    args="${args//-ld_classic /}"
    
    # Remove problematic libraries that may not be available during cross-compilation
    args="${args//-lswiftCore /}"
    args="${args//-lswiftFoundation /}"
    args="${args//-licucore /}"
    args="${args//-L\/usr\/lib\/swift /}"
    args="${args//-lobjc /}"
    args="${args//-lz /}"
    
    # Remove frameworks that may cause issues in cross-compilation
    args="${args//-framework CryptoKit /}"
    args="${args//-framework GSS /}"
    args="${args//-framework CoreFoundation /}"
    args="${args//-framework Foundation /}"
    args="${args//-framework Security /}"
    
elif [ "$is_macos_target" = true ]; then
    # Native macOS compilation using zig cc with proper library paths
    echo "Native macOS compilation using zig cc..."
    
    # Remove zig-unsupported flags but keep essential libraries and frameworks
    args="${args//-ld_classic /}"
    
    # Add library search paths to help zig find macOS system libraries
    extra_args="-L/usr/lib -L/usr/lib/swift -L/System/Library/Frameworks"
    args="$extra_args $args"
    
else
    # Linux-specific argument handling (existing logic)
    
    # Works around zlib not being available with zig. This is not great.
    args="${args//-lz /}"

    # Work around a .NET 8 Preview 6 issue
    args="${args//\'-Wl,-rpath,\$ORIGIN\'/-Wl,-rpath,\$ORIGIN}"

    # Work around parameters unsupported by zig. Just drop them from the command line.
    args="${args//--discard-all/--as-needed}"
    args="${args//-Wl,-pie /}"
    args="${args//-pie /}"
    args="${args//-Wl,-e0x0 /}"

    # Works around zig linker dropping necessary parts of the executable.
    args="-Wl,-u,__Module $args"
fi

# Use zig cc for all scenarios
zig cc $args