#!/bin/bash

# Check if zig is available
if ! command -v zig &> /dev/null; then
    echo "Error: zig is not on the PATH. Install zig and make sure it's on PATH. Follow instructions at https://github.com/MichalStrehovsky/PublishAotCross."
    exit 1
fi

# Get all arguments
args="$@"

# Check if we have a response file
response_file=""
if [[ "$args" == *"@"* ]]; then
    response_file=$(echo "$args" | grep -o '@[^[:space:]]*' | head -1 | cut -c2-)
fi

# Check if we're targeting Windows based on the --target argument in response file or args
is_windows_target=false
if [[ "$args" == *"--target="*"windows"* ]] || [[ -f "$response_file" && $(cat "$response_file") == *"--target="*"windows"* ]]; then
    is_windows_target=true
fi

if [ "$is_windows_target" = true ] && [ -n "$response_file" ] && [ -f "$response_file" ]; then
    # For Windows targets, create a new response file with converted arguments
    temp_response_file="${response_file}.tmp"
    
    # Process the response file line by line to avoid sed issues
    while IFS= read -r line; do
        # Remove BOM if present on first line
        if [[ "$line" =~ ^$'\uFEFF' ]]; then
            line="${line#$'\uFEFF'}"
        fi
        
        # Skip empty lines
        if [[ -z "$line" ]]; then
            continue
        fi
        
        # Convert Windows arguments to Unix equivalents
        if [[ "$line" =~ ^/OUT: ]]; then
            echo "-o $(echo "$line" | sed 's|/OUT:||')" >> "$temp_response_file"
        elif [[ "$line" =~ ^/DEF: ]]; then
            # Skip DEF files - not supported by zig
            continue
        elif [[ "$line" == "/NOLOGO" ]] || [[ "$line" == "/MANIFEST:NO" ]] || [[ "$line" == "/INCREMENTAL:NO" ]] || [[ "$line" == "/NOEXP" ]] || [[ "$line" == "/NOIMPLIB" ]] || [[ "$line" =~ ^/NATVIS: ]] || [[ "$line" == "/NODEFAULTLIB:libucrt.lib" ]] || [[ "$line" == "/DEFAULTLIB:ucrt.lib" ]] || [[ "$line" == "/OPT:ICF" ]]; then
            # Skip these unsupported options
            continue
        elif [[ "$line" == "/DEBUG" ]]; then
            echo '"-g"' >> "$temp_response_file"
        elif [[ "$line" == "/SUBSYSTEM:CONSOLE" ]]; then
            echo '"-Wl,--subsystem,console"' >> "$temp_response_file"
        elif [[ "$line" == "/SUBSYSTEM:WINDOWS" ]]; then
            echo '"-Wl,--subsystem,windows"' >> "$temp_response_file"
        elif [[ "$line" == "/ENTRY:wmainCRTStartup" ]]; then
            echo '"-Wl,--entry,wmainCRTStartup"' >> "$temp_response_file"
        elif [[ "$line" == "/OPT:REF" ]]; then
            echo '"-Wl,--gc-sections"' >> "$temp_response_file"
        elif [[ "$line" =~ \.lib\"?$ ]]; then
            # Convert .lib files to -l format for system libraries
            lib_name=$(echo "$line" | sed 's|"||g' | sed 's|\.lib$||')
            case "$lib_name" in
                advapi32|bcrypt|crypt32|iphlpapi|kernel32|mswsock|ncrypt|normaliz|ntdll|ole32|oleaut32|secur32|user32|version|ws2_32)
                    echo "\"-l$lib_name\"" >> "$temp_response_file"
                    ;;
                *)
                    # For runtime .lib files, change extension to .a
                    echo "$(echo "$line" | sed 's|\.lib|.a|g')" >> "$temp_response_file"
                    ;;
            esac
        else
            # Keep the line as-is
            echo "$line" >> "$temp_response_file"
        fi
    done < "$response_file"
    
    # Update args to use the modified response file
    args=$(echo "$args" | sed "s|@$response_file|@$temp_response_file|g")
    
    # Run zig cc with modified response file
    zig cc $args
    
    # Clean up
    rm -f "$temp_response_file"
elif [ "$is_windows_target" = true ]; then
    # Process inline arguments for Windows (no response file) - simplified version
    args="${args///OUT:/-o }"
    args="${args///DEBUG/-g}"
    
    # Convert Windows library names to Unix-style
    args="${args//advapi32\.lib/-ladvapi32}"
    args="${args//kernel32\.lib/-lkernel32}"
    args="${args//user32\.lib/-luser32}"
    
    # Run zig cc
    zig cc $args
else
    # Linux-specific workarounds (existing code)
    # Works around zlib not being available with zig. This is not great.
    args="${args//-lz /}"

    # Work around a .NET 8 Preview 6 issue
    args="${args//\'-Wl,-rpath,\$ORIGIN\'/-Wl,-rpath,\$ORIGIN}"

    # Work around parameters unsupported by zig. Just drop them from the command line.
    args="${args//--discard-all/--as-needed}"
    args="${args//-Wl,-pie /}"
    args="${args//-pie /}"
    args="${args//-Wl,-e0x0 /}"

    # Works around zig linker dropping necessary parts of the executable.
    args="-Wl,-u,__Module $args"
    
    # Run zig cc
    zig cc $args
fi